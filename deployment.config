# ARC Drive Deployment Configuration
# This file contains deployment settings for different environments

# =====================
# DEPLOYMENT ENVIRONMENTS
# =====================

# LOCAL ENVIRONMENT (Development/Testing)
[local]
TARGET_URL=http://localhost:4173
ENVIRONMENT=local
BUILD_DIR=dist
APP_HTML=app.html
PORT=4173
AUTO_DEPLOY=true
PREVIEW_SERVER=true

# STAGING ENVIRONMENT
[staging]
TARGET_URL=https://staging.arc-drive.example.com
ENVIRONMENT=staging
BUILD_DIR=dist
SSH_HOST=staging-server.com
SSH_USER=deploy
SSH_PATH=/var/www/arc-drive-staging
PORT=80
AUTO_DEPLOY=false
PREVIEW_SERVER=false

# PRODUCTION ENVIRONMENT
[production]
TARGET_URL=https://arc-drive.example.com
ENVIRONMENT=production
BUILD_DIR=dist
SSH_HOST=prod-server.com
SSH_USER=deploy
SSH_PATH=/var/www/arc-drive
PORT=80
AUTO_DEPLOY=false
PREVIEW_SERVER=false
BACKUP_BEFORE_DEPLOY=true

# =====================
# BUILD SETTINGS
# =====================
[build]
NODE_VERSION=18
NPM_VERSION=9.6.7
INSTALL_METHOD=npm
CACHE_DEPENDENCIES=true
CLEAN_BUILD=true
MINIFY=true

# =====================
# NOTIFICATION SETTINGS
# =====================
[notifications]
EMAIL_ON_SUCCESS=true
EMAIL_ON_FAILURE=true
EMAIL_RECIPIENTS=dev-team@example.com
SLACK_WEBHOOK_URL=${SLACK_WEBHOOK_URL}
SLACK_CHANNEL=#arc-drive-builds
SLACK_NOTIFY_SUCCESS=true
SLACK_NOTIFY_FAILURE=true

# =====================
# SECURITY SETTINGS
# =====================
[security]
REQUIRE_APPROVAL_FOR_PROD=true
RESTRICT_DEPLOYMENT_TIME=false
DEPLOYMENT_WINDOW_START=00:00
DEPLOYMENT_WINDOW_END=23:59
BACKUP_RETENTION_DAYS=7

# =====================
# HEALTH CHECK
# =====================
[healthcheck]
ENABLED=true
ENDPOINT=/app.html
TIMEOUT=30
RETRIES=3
RETRY_DELAY=5
